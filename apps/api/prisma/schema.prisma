generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Habit {
  id              String             @id @db.Uuid
  deviceId        String             @map("device_id")
  userId          String?            @map("user_id") @db.Uuid
  name            String
  emoji           String
  color           String
  shape           String
  goalType        String             @map("goal_type")
  targetCount     Int                @map("target_count")
  targetPeriod    String             @map("target_period")
  reminderEnabled Boolean            @default(false) @map("reminder_enabled")
  reminderTime    String?            @map("reminder_time")
  reminderCount   Int                @default(0) @map("reminder_count")
  reminderTimes   String[]           @default([]) @map("reminder_times")
  status          String
  createdAt       DateTime           @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime           @map("updated_at") @db.Timestamptz(6)
  completions     HabitCompletion[]
  user            User?              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([deviceId, status])
  @@index([userId, status])
  @@map("habits")
}

model HabitCompletion {
  id             String   @id @db.Uuid
  habitId        String   @map("habit_id") @db.Uuid
  deviceId       String   @map("device_id")
  completionDate DateTime @map("completion_date") @db.Date
  count          Int
  createdAt      DateTime @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @map("updated_at") @db.Timestamptz(6)
  habit          Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, completionDate])
  @@index([habitId, completionDate])
  @@map("habit_completions")
}

model User {
  id                  String               @id @db.Uuid
  email               String?              @unique
  displayName         String?              @map("display_name")
  createdAt           DateTime             @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime             @map("updated_at") @db.Timestamptz(6)
  habits              Habit[]
  identities          AuthIdentity[]
  passwordCredential  PasswordCredential?
  refreshSessions     RefreshSession[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model AuthIdentity {
  id         String   @id @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  provider   String
  subject    String
  email      String?
  createdAt  DateTime @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @map("updated_at") @db.Timestamptz(6)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, subject])
  @@index([userId])
  @@map("auth_identities")
}

model PasswordCredential {
  userId       String   @id @map("user_id") @db.Uuid
  passwordHash String   @map("password_hash")
  createdAt    DateTime @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @map("updated_at") @db.Timestamptz(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_credentials")
}

model RefreshSession {
  id           String   @id @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  tokenHash    String   @map("token_hash")
  expiresAt    DateTime @map("expires_at") @db.Timestamptz(6)
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt    DateTime @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @map("updated_at") @db.Timestamptz(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_sessions")
}

model PasswordResetToken {
  id        String   @id @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime @map("created_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}
